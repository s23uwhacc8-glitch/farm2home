NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/farm2home
JWT_SECRET=your_secret_here_min_32_chars
JWT_EXPIRY=7d
ADMIN_EMAIL=admin@farm2home.com
ADMIN_PASSWORD=Admin@123456
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=30
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ── Cloudinary (required for image uploads) ────────────────────────────────────
# Sign up free at https://cloudinary.com → Dashboard → copy these three values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: enables AI Price Advisor in the Farmer dashboard
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
